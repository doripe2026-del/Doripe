{
  "name": "doripe",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vercel dev",
    "dev:landing": "node scripts/serve-landing.mjs",
    "build": "npm run build:home-css && npm run typecheck",
    "vercel-build": "npm run build:home-css && npm run typecheck",
    "build:home-css": "tailwindcss -c scripts/tailwind.home.config.cjs -i scripts/home-tailwind.css -o public/home/home.css --minify",
    "guard:repo": "node scripts/guard-repository.mjs",
    "check:session": "node scripts/check-session-context.mjs",
    "check:supabase": "node scripts/check-supabase-migrations.mjs",
    "check:ops": "node scripts/check-ops-readiness.mjs",
    "setup:guards": "node scripts/setup-local-guards.mjs",
    "setup:deployment-guard": "node scripts/install-deployment-shell-guard.mjs",
    "check:mvp-app": "node scripts/check-mvp-app.mjs",
    "build:admin": "node scripts/build-admin.mjs",
    "typecheck": "tsc --noEmit",
    "sync:home": "node scripts/sync-home-index.mjs",
    "test:landing-motion": "node --test tests/landing-*.test.mjs",
    "test:booth-devices": "playwright test --config=tests/playwright.booth.config.ts",
    "test:landing-motion:geometry": "node tests/landing-route-geometry.browser.mjs",
    "check:landing-motion": "node scripts/check-landing-motion.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.4",
    "@vercel/postgres": "^0.10.0",
    "chart.js": "^4.5.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/node": "^22.13.5",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vercel/node": "^5.1.0",
    "esbuild": "^0.27.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "vercel": "^54.11.1"
  }
}

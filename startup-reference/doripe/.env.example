# Vercel Postgres가 자동 주입 (vercel env pull 또는 dashboard storage 연결 시)
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# Admin 비밀번호 — 직접 채울 것 (HMAC 쿠키 secret으로도 사용)
ADMIN_PASSWORD=change-me-please

# 시드 지역 (메타 description 등에 사용)
SEED_NEIGHBORHOOD=서울숲 한강 다리

# NAVER Maps API
NAVER_MAPS_CLIENT_ID=
NAVER_MAPS_CLIENT_SECRET=

# Supabase service-role access for Vercel API routes.
# Never expose SUPABASE_SERVICE_ROLE_KEY in browser code.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/company", "destination": "/home/company.html" },
    { "source": "/notify", "destination": "/home/notify.html" },
    { "source": "/privacy", "destination": "/home/privacy.html" },
    { "source": "/terms", "destination": "/home/terms.html" },
    { "source": "/admin/:path*", "destination": "/admin/index.html" },
    { "source": "/api/v1/:path*", "destination": "/api/v1?__path=:path*" },
    { "source": "/app-preview", "destination": "/app-preview/index.html" },
    { "source": "/app", "destination": "/app-preview/index.html" },
    { "source": "/app/:path*", "destination": "/app-preview/index.html" },
    { "source": "/blog", "destination": "/blog/index.html" },
    { "source": "/p/:shareId", "destination": "/api/share?type=place&shareId=:shareId" },
    { "source": "/r/:shareId", "destination": "/api/share?type=route&shareId=:shareId" },
    { "source": "/shares/:shareId", "destination": "/share.html" },
    { "source": "/s/:shareId", "destination": "/share.html" },
    { "source": "/open", "destination": "/share.html" },
    { "source": "/", "destination": "/home/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), payment=(), usb=(), geolocation=(self)" }
      ]
    },
    {
      "source": "/img/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
